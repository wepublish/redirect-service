# Host where the admin UI + OAuth live (e.g. redirects.wepublish.ch)
ADMIN_HOSTNAME=redirects.example.com
# Value operators point their CNAME at; defaults to ADMIN_HOSTNAME if unset
CNAME_TARGET=redirects.example.com
# Let's Encrypt
ACME_EMAIL=ops@example.com
ACME_CA=https://acme-v02.api.letsencrypt.org/directory
# GitHub OAuth app
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=https://redirects.example.com/auth/github/callback
ALLOWED_GITHUB_ORG=wepublish
# Optional: restrict sign-in to one team (group) within the org. Use the team
# *slug* (lowercase, hyphenated). Leave empty to allow any org member.
ALLOWED_GITHUB_TEAM=
# Signs the session cookie (random 32+ char string)
SESSION_SECRET=change-me-to-a-long-random-string
# Optional local dev login (leave unset in production to disable)
DEV_ADMIN_USER=
DEV_ADMIN_PASSWORD=
# Data + cert directory
DATA_DIR=./data
