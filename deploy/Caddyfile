{
	# Bind unprivileged ports inside the container; Docker publishes host
	# 80 -> 8080 and 443 -> 4443, so the container needs no root.
	http_port 8080
	https_port 4443

	# Email for ACME registration
	email {$ACME_EMAIL}
	# Ask endpoint gates on-demand cert issuance to registered domains
	on_demand_tls {
		ask http://127.0.0.1:3000/internal/tls-allowed
	}
	# ACME directory (prod by default; override with ACME_CA for staging)
	acme_ca {$ACME_CA:https://acme-v02.api.letsencrypt.org/directory}
}

# HTTPS for any host; certs obtained on-demand subject to the ask endpoint.
https:// {
	tls {
		on_demand
	}
	reverse_proxy 127.0.0.1:3000
}

# Plain HTTP is proxied straight to the app (no forced HTTPS redirect): the app
# emits the configured redirect to an absolute URL, and Caddy still answers
# ACME HTTP-01 challenges on this listener.
http:// {
	reverse_proxy 127.0.0.1:3000
}
